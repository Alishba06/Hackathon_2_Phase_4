# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Neon Serverless PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ===========================================
# AUTHENTICATION
# ===========================================
# Better Auth secret key (generate a random string)
# Recommended: openssl rand -hex 32
BETTER_AUTH_SECRET=your-super-secret-auth-key-change-this-in-production

# JWT secret key for token signing
# Recommended: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Backend API base URL (accessible from browser)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Better Auth URL (accessible from browser)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:8000

# JWT secret (public key for frontend verification)
NEXT_PUBLIC_JWT_SECRET=your-public-jwt-secret

# ===========================================
# BACKEND CONFIGURATION
# ===========================================
# CORS allowed origins (Python list format)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# NEON DB PROXY (Optional - for local development)
# ===========================================
# Same as DATABASE_URL but for the proxy service
NEON_SERVERLESS_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
